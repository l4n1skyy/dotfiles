#!/bin/bash

# 1. Favorites List
POKEMON_LIST=(yveltal)

# 2. Fetcher setup (ignores the internal logo)
FETCHER="fastfetch --logo none"
FETCHER_HEIGHT=$($FETCHER | wc -l)

# 3. Aesthetics
EXTRA_PADDING_H=2
EXTRA_PADDING_W=0
WIDTH=38

# 4. Get the sprite
sprite=$(pokeget ${POKEMON_LIST[RANDOM % ${#POKEMON_LIST[@]}]} --hide-name)
height=$(echo "$sprite" | wc -l)

# 5. The Math: Vertical Centering
# Formula: (Fetcher lines - Sprite lines) / 2 + offset
pad_top=$((($FETCHER_HEIGHT - $height) / 2))
pad_top=$((pad_top + EXTRA_PADDING_H))
(( pad_top < 0 )) && pad_top=0

# 6. The Math: Horizontal Centering
sprite_width=$(printf '%s\n' "$sprite" | sed 's/\x1b\[[0-9;]*m//g' | awk '{ if (length > max) max = length } END { print max }')
pad_Left=$((($WIDTH - sprite_width) / 2))
pad_Left=$((pad_Left + EXTRA_PADDING_W))
(( pad_Left < 0 )) && pad_Left=0

# 7. Execution
echo "$sprite" | $FETCHER --file-raw - --logo-padding-top $pad_top --logo-padding-left $pad_Left
